# API-ключ для защиты эндпоинтов (придумайте сложный, например через `openssl rand -hex 32`)
API_KEY=test-key

# Настройки подключения к базе данных
DB_USER=polyflip
DB_PASSWORD=secret
DB_NAME=polyflip

# Активы для мониторинга (через запятую)
ASSETS=BTC,ETH,SOL,XRP,DOGE

# Все остальные параметры (INTERVALS, MIN_EDGE и т.д.) теперь управляются
# через дашборд во вкладке "Настройки" (сохраняются в БД).
